# ── Formspree (contact form) ──────────────────────────────────────────────────
# Create a free account at https://formspree.io and paste your form ID here
VITE_FORMSPREE_ID=your_formspree_form_id

# ── Anthropic API (AI chat terminal) ──────────────────────────────────────────
# Get your API key at https://console.anthropic.com
# NOTE: This key will be visible in the browser for demo/portfolio purposes.
# For production, proxy the request through a serverless function instead.
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── GitHub API (optional) ─────────────────────────────────────────────────────
# Increases rate limit from 60 to 5000 requests/hour
# Create a token at https://github.com/settings/tokens (no scopes needed)
VITE_GITHUB_TOKEN=ghp_your_token_here
